    "# TODO Ecrire votre code ici pour la question bonus\n",
    "indices = df_steam_clean.value_counts(\"Type_prix\").index\n",
    "df_count = pd.DataFrame(df_steam_clean.value_counts(\"Type_prix\")).reset_index()\n",
    "df_prop = stats_par_groupe(df_steam_clean, 'Type_prix', 'Bien_note_bin', ['mean']).drop(['Statistique'], axis='columns')\n",
    "\n",
    "high_bar = df_count.loc[:, \"count\"]\n",
    "low_bar = pd.Series([high_bar[i] * (1 - df_prop.loc[i, \"Valeur\"]) for i in df_count.index])\n",
    "\n",
    "plt.bar(indices, high_bar, 0.8, color='b', label=\"Mal noté\")\n",
    "plt.bar(indices, low_bar, 0.8, color='r', label=\"Bien noté\")\n",
    "\n",
    "plt.xlabel(\"Type de prix\")\n",
    "plt.ylabel(\"Nombre de jeux\")\n",
    "plt.title(\"Répartition jeux bien notés et mal notés selon le type de prix\")\n",
    "plt.legend()\n",
    "plt.show()\n"
   ]
